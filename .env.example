# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foji_dev

# ── Auth ─────────────────────────────────────────────────────
INTERNAL_API_KEY=change-me-shared-secret-with-foji-api

# ── AI Providers ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DYNAMODB_TABLE=foji-chats-dev
AWS_S3_BUCKET=foji-files-dev

# ── App ──────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:4321
